<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CTRExploreSD.ViewModels"
        x:Class="CTRExploreSD.Views.FtpExplorerWindow"
        x:DataType="vm:FtpExplorerViewModel"
        x:Name="RootWindow"
        Width="600" Height="500"
        Title="CTRExploreSD - FTP mode">

    <Grid>
        <Grid RowDefinitions="Auto, *, Auto" Margin="10">
            
            <Border Grid.Row="0" Background="#E0E0E0" Padding="5" CornerRadius="3" Margin="0,0,0,10">
                <TextBlock Text="{Binding CurrentPath}" FontWeight="Bold" VerticalAlignment="Center" Foreground="Black"/>
            </Border>

            <ListBox Grid.Row="1" ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedItem}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto, *, Auto, Auto" Margin="5" DoubleTapped="OnItemDoubleTapped" Background="Transparent">
                            <TextBlock Grid.Column="0" Text="{Binding Icon}" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}"/>
                            <TextBlock Grid.Column="2" Text="{Binding Risk}" Foreground="{Binding Color}" FontWeight="Bold" Margin="0,0,15,0"/>
                            <TextBlock Grid.Column="3" Text="{Binding SizeDisplay}" Foreground="Gray"/>
                            
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open / Navigate" Command="{Binding #RootWindow.((vm:FtpExplorerViewModel)DataContext).OpenItemCommand}" CommandParameter="{Binding}" />
                                    <MenuItem Header="Download to PC..." Click="OnDownloadClick" />
                                    <MenuItem Header="Properties" Command="{Binding #RootWindow.((vm:FtpExplorerViewModel)DataContext).ShowPropertiesCommand}" CommandParameter="{Binding}" />
                                    <MenuItem Header="-" /> 
                                    <MenuItem Header="Delete (Warning)" Command="{Binding #RootWindow.((vm:FtpExplorerViewModel)DataContext).DeleteSelectedItemCommand}" Foreground="Red" />
                                </ContextMenu>
                            </Grid.ContextMenu>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Margin="0,10,0,0" Foreground="Gray"/>
        </Grid>

        <Border IsVisible="{Binding IsPropertiesVisible}" Background="#90000000" ZIndex="100">
            <Border Background="White" Padding="20" CornerRadius="10" Width="350" VerticalAlignment="Center" HorizontalAlignment="Center" BoxShadow="0 5 15 0 #80000000">
                <StackPanel Spacing="15">
                    <TextBlock Text="Item Properties" FontSize="18" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding PropertiesText}" Foreground="Black" TextWrapping="Wrap" LineHeight="25"/>
                    <Button Content="Close" Command="{Binding ClosePropertiesCommand}" HorizontalAlignment="Center" Background="#2196F3" Foreground="White" Padding="20,5"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>

</Window>